    function changeLanguage(lang, element) {
        // Ενημέρωση ενεργής σημαίας
        document.querySelectorAll('.flag').forEach(f => f.classList.remove('active'));
        element.classList.add('active');

        // Μετάφραση στοιχείων με data-key
        document.querySelectorAll('[data-key]').forEach(el => {
            const key = el.getAttribute('data-key');
            if (translations[lang][key]) {
                el.innerText = translations[lang][key];
            }
        });

        // Επαναδημιουργία λίστας τηλεφώνων (για να μεταφραστούν οι ετικέτες και η λέξη "Κλήση")
        renderPhones(lang);
    }

    function renderPhones(lang) {
        const phones = [
            { id: "fire", icon: "🔥", color: "icon-red", num: "199" },
            { id: "police", icon: "🛡️", color: "icon-blue", num: "100" },
            { id: "ambulance", icon: "🚑", color: "icon-green", num: "166" },
            { id: "emergency", icon: "⚠️", color: "icon-yellow", num: "112" },
            { id: "health_center", icon: "🏥", color: "icon-purple", num: "2844340000" },
            { id: "poison_center", icon: "💀", color: "icon-red", num: "+302107793777" }
        ];

        const list = document.getElementById('phoneList');
        if (!list) return;
        
        list.innerHTML = phones.map(p => `
            <a href="tel:${p.num}" class="info-card">
                <div class="icon-box ${p.color}">${p.icon}</div>
                <div class="info-details">
                    <div class="label">${translations[lang][p.id]}</div>
                    <div class="value">${p.num} <span class="call-tag">${translations[lang].call}</span></div>
                </div>
            </a>
        `).join('');
    }

    function showPage(pageId) {
        document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
        document.getElementById(pageId).classList.add('active');
        window.scrollTo(0,0);
    }

    // Αρχική φόρτωση τηλεφώνων στα Ελληνικά
    renderPhones('gr');
</script>

